<div class="auth-page auth-page-master-control min-h-[100svh] flex items-center justify-center px-4 py-10" x-data="{ mode: 'login' }">
  <div class="w-full max-w-md">
    <div class="auth-card auth-card-danger rounded-[1.125rem] border p-6 sm:p-7">
      <div class="mb-6 text-center">
        <a href="<%= root_path %>" data-turbo="false" class="inline-flex items-center justify-center rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-800">
          SaaS Template
        </a>

        <h1 class="auth-brand-title mt-5 text-[1.7rem] font-semibold tracking-[-0.03em] leading-tight">
          <span x-show="mode === 'login'">Master Control Sign in</span>
          <span x-show="mode === 'create'" x-cloak>Create Workspace</span>
        </h1>
      </div>

      <%= render "shared/flash" %>

      <div x-show="mode === 'login'" x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 -translate-x-4" x-transition:enter-end="opacity-100 translate-x-0">
        <div
          class="relative"
          x-data='{
            query: "",
            fetching: false,
            items: [],
            open: false,
            activeIndex: -1,
            selectedEmail: "",
            selectedTenantId: "",
            navigating: false,

            csrf() {
              const t = document.querySelector("meta[name=csrf-token]");
              return t ? t.getAttribute("content") : "";
            },

            async fetchSuggestions() {
              const q = this.query.trim();
              if (q.length < 2) {
                this.items = [];
                this.open = false;
                this.activeIndex = -1;
                return;
              }
              this.fetching = true;
              try {
                const url = "<%= tenant_login_accounts_email_suggestions_path %>?q=" + encodeURIComponent(q);
                const resp = await fetch(url, {
                  method: "GET",
                  credentials: "same-origin",
                  headers: { "Accept": "application/json" }
                });
                if (!resp.ok) return;
                const data = await resp.json();
                this.items = Array.isArray(data.items) ? data.items : [];
                this.open = this.items.length > 0;
                this.activeIndex = this.open ? 0 : -1;
              } finally {
                this.fetching = false;
              }
            },

            choose(idx) {
              if (idx < 0 || idx >= this.items.length) return;
              const item = (window.Alpine && Alpine.raw) ? Alpine.raw(this.items[idx]) : { ...this.items[idx] };
              const email = item.email || "";
              const tenantId = item.tenant_id || "";

              this.navigating = true;
              this.open = false;

              const form = document.createElement("form");
              form.method = "POST";
              form.action = "<%= main_app.new_tenant_login_account_otp_login_path %>";
              form.style.display = "none";

              const token = document.createElement("input");
              token.type = "hidden";
              token.name = "authenticity_token";
              token.value = this.csrf();
              form.appendChild(token);

              const fEmail = document.createElement("input");
              fEmail.type = "hidden";
              fEmail.name = "email";
              fEmail.value = email;
              form.appendChild(fEmail);

              const fTenant = document.createElement("input");
              fTenant.type = "hidden";
              fTenant.name = "tenant_id";
              fTenant.value = tenantId;
              form.appendChild(fTenant);

              document.body.appendChild(form);
              requestAnimationFrame(() => { setTimeout(() => form.submit(), 30); });
            },

            move(delta) {
              if (!this.open || this.items.length === 0) return;
              this.activeIndex = (this.activeIndex + delta + this.items.length) % this.items.length;
            }
          }'
          @click.outside="open = false"
          :aria-busy="navigating ? 'true' : 'false'"
        >
          <label class="auth-label mb-2 block text-[11px] font-medium uppercase tracking-[0.08em]" for="login_email_input">Admin Email</label>

          <div class="relative">
            <input
              id="login_email_input"
              type="email"
              name="login_email_input"
              placeholder="support@example.test"
              class="auth-input block w-full rounded-xl border p-3 pr-9 text-sm"
              autocomplete="off" autocapitalize="none" autocorrect="off" spellcheck="false" inputmode="email"
              x-model="query"
              @focus="open = (query.trim().length >= 2 && items.length > 0)"
              @input.debounce.550ms="fetchSuggestions()"
              @keydown.down.prevent="move(1)"
              @keydown.up.prevent="move(-1)"
              @keydown.enter.prevent="choose(activeIndex)"
              @keydown.escape.stop="open = false"
              :disabled="navigating"
              required
            >

            <div class="auth-label absolute inset-y-0 right-3 flex items-center text-xs" x-show="fetching" x-cloak>…</div>

            <div
              x-show="open"
              x-cloak
              class="auth-dropdown absolute left-0 right-0 z-10 mt-2 rounded-xl border"
              role="listbox"
              :aria-activedescendant="'opt-'+activeIndex"
            >
              <ul class="max-h-60 overflow-auto py-1.5">
                <template x-for="(item, idx) in items" :key="item.email + ':' + item.tenant_id">
                  <li
                    :id="'opt-'+idx"
                    role="option"
                    @mouseenter="activeIndex = idx"
                    @mouseleave="activeIndex = -1"
                    @click="choose(idx)"
                    :class="idx === activeIndex ? 'auth-option-active' : 'auth-option-idle'"
                    class="cursor-pointer px-3 py-2.5 text-sm flex items-center justify-between transition-colors"
                  >
                    <span x-text="item.email"></span>
                    <span class="auth-label ml-2 text-[10px]" x-text="item.tenant_name || item.tenant_id?.slice(0,8)"></span>
                  </li>
                </template>
              </ul>
            </div>
          </div>

          <p class="auth-meta mt-3 text-[12px] leading-5">
            Enter your admin email, then click your address to send a login code.
          </p>

          <div
            x-show="navigating"
            x-cloak
            class="auth-overlay absolute inset-0 grid place-items-center rounded-2xl backdrop-blur-sm"
            role="status"
            aria-live="polite"
          >
            <div class="flex items-center gap-2 text-sm">
              <svg class="h-4 w-4 animate-spin" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" />
                <path d="M22 12a10 10 0 00-10-10" stroke="currentColor" stroke-width="4" stroke-linecap="round" />
              </svg>
              Preparing your login code…
            </div>
          </div>
        </div>
      </div>

      <div x-show="mode === 'create'" x-cloak x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 translate-x-4" x-transition:enter-end="opacity-100 translate-x-0">
        <%= form_with url: admin_create_tenant_path, method: :post, local: true, class: "space-y-3" do |f| %>
          <div>
            <label class="auth-label mb-2 block text-[11px] font-medium uppercase tracking-[0.08em]">Workspace Name</label>
            <%= f.text_field :name, required: true, placeholder: "Acme Inc", class: "auth-input block w-full rounded-xl border p-3 text-sm" %>
          </div>

          <div>
            <label class="auth-label mb-2 block text-[11px] font-medium uppercase tracking-[0.08em]">Subdomain</label>
            <div class="flex">
              <%= f.text_field :subdomain, required: true, placeholder: "acme", class: "auth-input block w-full rounded-l-xl border p-3 text-sm text-right" %>
              <span class="auth-addon inline-flex items-center rounded-r-xl border border-l-0 px-3 text-xs">
                .<%= ENV.fetch("APP_CANONICAL_HOST", "example.com") %>
              </span>
            </div>
          </div>

          <div>
            <label class="auth-label mb-2 block text-[11px] font-medium uppercase tracking-[0.08em]">Time Zone</label>
            <%= f.time_zone_select :time_zone, ActiveSupport::TimeZone.all, { default: "UTC" }, { class: "auth-input block w-full rounded-xl border p-3 text-sm" } %>
          </div>

          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="auth-label mb-2 block text-[11px] font-medium uppercase tracking-[0.08em]">First Name</label>
              <%= f.text_field :owner_first_name, required: true, class: "auth-input block w-full rounded-xl border p-3 text-sm" %>
            </div>
            <div>
              <label class="auth-label mb-2 block text-[11px] font-medium uppercase tracking-[0.08em]">Last Name</label>
              <%= f.text_field :owner_last_name, required: true, class: "auth-input block w-full rounded-xl border p-3 text-sm" %>
            </div>
          </div>

          <div>
            <label class="auth-label mb-2 block text-[11px] font-medium uppercase tracking-[0.08em]">Owner Email</label>
            <%= f.email_field :owner_email, required: true, placeholder: "admin@acme.com", class: "auth-input block w-full rounded-xl border p-3 text-sm" %>
          </div>

          <button type="submit" class="auth-button w-full inline-flex items-center justify-center rounded-xl border px-3 py-3 text-sm font-medium">
            Create Workspace
          </button>
        <% end %>
      </div>

      <% support_email = Rails.application.credentials.dig(:support, :email) || ENV["SUPPORT_EMAIL"] || "support@example.test" %>
      <div class="auth-meta mt-5 text-center text-[12px] leading-5">
        <button @click="mode = mode === 'login' ? 'create' : 'login'" type="button" class="auth-link font-medium">
          <span x-show="mode === 'login'">Create Workspace</span>
          <span x-show="mode === 'create'" x-cloak>Back to Sign in</span>
        </button>
        <span class="mx-2">·</span>
        Need help?
        <%= mail_to support_email, support_email, class: "auth-link font-medium" %>
      </div>
    </div>
  </div>
</div>
