<!DOCTYPE html>
<html>
  <head>
    <script>
      (function() {
        var t = localStorage.getItem('theme');
        if (t === 'dark') document.documentElement.classList.add('dark');
      })();
    </script>
    <title><%= content_for(:title) || "SaaS Template" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= render "layouts/share/head_set_up" %>
    <%= yield :head %>

    <style>
      [v-cloak], .loading { display: none; }

      :root {
        --bg-base:        #faf8f5;
        --bg-surface:     #ffffff;
        --bg-elevated:    #f3f0ea;
        --bg-hover:       rgba(0,0,0,0.05);
        --border:         #e2ddd7;
        --border-subtle:  #ebe7e0;
        --text-primary:   #18160e;
        --text-secondary: #3d3830;
        --text-muted:     #86807a;
        --text-faint:     #afa9a3;
        --glass-bg:       rgba(250,248,245,0.92);
        --glass-border:   rgba(0,0,0,0.08);
      }
      .dark {
        --bg-base:        #030712;
        --bg-surface:     #080f1a;
        --bg-elevated:    #0f1829;
        --bg-hover:       rgba(255,255,255,0.05);
        --border:         #1a2436;
        --border-subtle:  #111827;
        --text-primary:   #f3f4f6;
        --text-secondary: #d1d5db;
        --text-muted:     #9ca3af;
        --text-faint:     #6b7280;
        --glass-bg:       rgba(3,7,18,0.90);
        --glass-border:   rgba(255,255,255,0.05);
      }

      .bg-base               { background-color: var(--bg-base); }
      .bg-surface            { background-color: var(--bg-surface); }
      .bg-elevated           { background-color: var(--bg-elevated); }
      .text-primary          { color: var(--text-primary); }
      .text-secondary        { color: var(--text-secondary); }
      .text-muted            { color: var(--text-muted); }
      .text-faint            { color: var(--text-faint); }
      .border-theme          { border-color: var(--border); }
      .border-subtle         { border-color: var(--border-subtle); }
      .divide-theme > * + * { border-color: var(--border); }
      .hover\:bg-elevated:hover  { background-color: var(--bg-elevated); }
      .hover\:bg-hover:hover     { background-color: var(--bg-hover); }
      .hover\:text-primary:hover { color: var(--text-primary); }
      .ring-theme                { --tw-ring-color: var(--border); }

      /* ── Status / amortization badges ── */
      .badge-blue    { background:#dbeafe; color:#1e40af; border-color:#bfdbfe; }
      .badge-purple  { background:#f3e8ff; color:#6b21a8; border-color:#e9d5ff; }
      .badge-red     { background:#fee2e2; color:#991b1b; border-color:#fecaca; }
      .badge-emerald { background:#d1fae5; color:#065f46; border-color:#a7f3d0; }
      .badge-sky     { background:#e0f2fe; color:#075985; border-color:#bae6fd; }
      .badge-amber   { background:#fef3c7; color:#78350f; border-color:#fde68a; }
      .badge-gray    { background:#f3f4f6; color:#6b7280; border-color:#e5e7eb; }
      .dark .badge-blue    { background:rgba(30,64,175,.2);  color:#93c5fd; border-color:rgba(59,130,246,.3); }
      .dark .badge-purple  { background:rgba(88,28,135,.3);  color:#d8b4fe; border-color:rgba(139,92,246,.3); }
      .dark .badge-red     { background:rgba(127,29,29,.3);  color:#fca5a5; border-color:rgba(220,38,38,.3); }
      .dark .badge-emerald { background:rgba(6,78,59,.3);    color:#6ee7b7; border-color:rgba(16,185,129,.3); }
      .dark .badge-sky     { background:rgba(7,89,133,.3);   color:#7dd3fc; border-color:rgba(14,165,233,.3); }
      .dark .badge-amber   { background:rgba(120,53,15,.3);  color:#fbbf24; border-color:rgba(245,158,11,.3); }
      .dark .badge-gray    { background:#1f2937;             color:#9ca3af; border-color:#374151; }

      /* ── Soft action buttons ── */
      .btn-soft-blue { background:rgba(219,234,254,0.65); color:#1d4ed8; border-color:rgba(147,197,253,0.55); }
      .btn-soft-blue:hover { background:rgba(191,219,254,0.85); }
      .dark .btn-soft-blue { background:rgba(30,64,175,0.25); color:#93c5fd; border-color:rgba(59,130,246,0.3); }
      .dark .btn-soft-blue:hover { background:rgba(30,64,175,0.4); }
      .btn-soft-danger { background:rgba(254,226,226,0.65); color:#991b1b; border-color:rgba(254,202,202,0.55); }
      .btn-soft-danger:hover { background:rgba(254,202,202,0.85); }
      .dark .btn-soft-danger { background:rgba(127,29,29,0.22); color:#fca5a5; border-color:rgba(220,38,38,0.3); }
      .dark .btn-soft-danger:hover { background:rgba(127,29,29,0.38); }

      /* ── Tab active states ── */
      .tab-active-blue   { background:rgba(219,234,254,0.7); color:#1d4ed8; }
      .tab-active-purple { background:rgba(243,232,255,0.7); color:#6b21a8; }
      .dark .tab-active-blue   { background:rgba(30,64,175,0.3);  color:#93c5fd; }
      .dark .tab-active-purple { background:rgba(88,28,135,0.3);  color:#d8b4fe; }

      /* ── Flash messages ── */
      .flash-ok      { border-color:rgba(6,182,212,0.4);   background:rgba(236,253,245,0.95); color:#065f46; }
      .flash-bad     { border-color:rgba(220,38,38,0.3);   background:rgba(254,242,242,0.95); color:#991b1b; }
      .flash-warning { border-color:rgba(245,158,11,0.35); background:rgba(255,251,235,0.95); color:#78350f; }
      .flash-info    { border-color:rgba(59,130,246,0.35); background:rgba(239,246,255,0.95); color:#1e40af; }
      .dark .flash-ok      { border-color:rgba(6,182,212,0.3);   background:rgba(6,78,59,0.25);     color:#6ee7b7; }
      .dark .flash-bad     { border-color:rgba(220,38,38,0.3);   background:rgba(127,29,29,0.25);   color:#fca5a5; }
      .dark .flash-warning { border-color:rgba(245,158,11,0.3);  background:rgba(120,53,15,0.25);   color:#fbbf24; }
      .dark .flash-info    { border-color:rgba(59,130,246,0.3);  background:rgba(30,64,175,0.25);   color:#93c5fd; }

      /* ── Inline panel banners ── */
      .panel-info    { background:rgba(239,246,255,0.8); border-color:rgba(147,197,253,0.45); color:#1e40af; }
      .panel-warning { background:rgba(255,251,235,0.85); border-color:rgba(217,119,6,0.35); color:#78350f; }
      .dark .panel-info    { background:rgba(30,64,175,0.15);  border-color:rgba(59,130,246,0.25);  color:#93c5fd; }
      .dark .panel-warning { background:rgba(120,53,15,0.15);  border-color:rgba(217,119,6,0.3);   color:#fbbf24; }

      /* ── Dynamic Alpine.js badge classes (cash events / breakdown) ── */
      .badge-dir-in        { background:rgba(209,250,229,0.8); color:#065f46; border-color:rgba(167,243,208,0.9); }
      .badge-dir-in-void   { background:rgba(209,250,229,0.25); color:rgba(6,95,70,0.45); border-color:rgba(167,243,208,0.3); }
      .badge-dir-out       { background:rgba(254,243,199,0.8); color:#92400e; border-color:rgba(253,211,77,0.7); }
      .badge-dir-out-void  { background:rgba(254,243,199,0.25); color:rgba(120,53,15,0.45); border-color:rgba(253,211,77,0.3); }
      .badge-cat-repayment      { background:rgba(219,234,254,0.8); color:#1e40af; border-color:rgba(191,219,254,0.9); }
      .badge-cat-repayment-void { background:rgba(219,234,254,0.25); color:rgba(30,64,175,0.4); border-color:rgba(191,219,254,0.3); }
      .dark .badge-dir-in        { background:rgba(6,78,59,0.25);    color:#6ee7b7; border-color:rgba(16,185,129,0.4); }
      .dark .badge-dir-in-void   { background:rgba(6,78,59,0.08);    color:rgba(110,231,183,0.35); border-color:rgba(16,185,129,0.15); }
      .dark .badge-dir-out       { background:rgba(120,53,15,0.25);  color:#fbbf24; border-color:rgba(245,158,11,0.4); }
      .dark .badge-dir-out-void  { background:rgba(120,53,15,0.08);  color:rgba(251,191,36,0.35); border-color:rgba(245,158,11,0.15); }
      .dark .badge-cat-repayment      { background:rgba(30,64,175,0.2);  color:#93c5fd; border-color:rgba(59,130,246,0.3); }
      .dark .badge-cat-repayment-void { background:rgba(30,64,175,0.06); color:rgba(147,197,253,0.35); border-color:rgba(59,130,246,0.12); }

      /* ── Column group tints (installment schedule) ── */
      .bg-tint-amber   { background-color: rgba(255,251,235,0.7); }
      .bg-tint-emerald { background-color: rgba(240,253,244,0.7); }
      .bg-tint-rose    { background-color: rgba(255,241,242,0.7); }
      .dark .bg-tint-amber   { background-color: rgba(120,53,15,0.18); }
      .dark .bg-tint-emerald { background-color: rgba(6,78,59,0.18); }
      .dark .bg-tint-rose    { background-color: rgba(136,19,55,0.18); }
      .border-tint-amber   { border-color: rgba(253,211,77,0.5); }
      .border-tint-emerald { border-color: rgba(52,211,153,0.35); }
      .border-tint-rose    { border-color: rgba(251,113,133,0.35); }
      .dark .border-tint-amber   { border-color: rgba(180,83,9,0.4); }
      .dark .border-tint-emerald { border-color: rgba(6,95,70,0.4); }
      .dark .border-tint-rose    { border-color: rgba(159,18,57,0.3); }

      .glass-header {
        background: var(--glass-bg);
        border-color: var(--glass-border);
        -webkit-backdrop-filter: blur(10px);
        backdrop-filter: blur(10px);
      }
      @supports not ((-webkit-backdrop-filter: blur(0)) or (backdrop-filter: blur(0))) {
        .glass-header { background: var(--glass-bg); opacity: 0.98; }
      }
    </style>
  </head>

  <body class="antialiased bg-base" <%= 'data-turbo="false"' if safari_browser? %>>
    <%= yield %>
    <%= render "layouts/share/body_set_up" %>

    <script>
      // Show the body as soon as the DOM is ready 
      // Tailwind CDN will usually have finished its first pass by then
      document.addEventListener("DOMContentLoaded", () => {
        document.body.style.visibility = "visible";
      });
    </script>

  </body>
</html>
