    <style>
      html, body {
        font-family: "Oxanium", ui-sans-serif, system-ui, -apple-system,
                     "Segoe UI", Roboto, "Helvetica Neue", Arial, "Noto Sans",
                     "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol", "Noto Color Emoji";

        background-color: var(--bg-base, #faf8f5);
        color: var(--text-secondary, #3d3830);
      }
      :root { --header-h: 64px; --footer-h: 56px; }
    </style>
    <style>
      .pagy {
        --B: 1; --H: 0; --S: 0; --L: 50; --A: 1;
        --spacing: 0.125rem; --padding: 0.35rem; --rounding: 0.25rem;
        --border-width: 1px; --font-size: 0.6875rem; --font-weight: 600; --line-height: 1.2;
        --text:               hsla(var(--H) var(--S) calc(var(--L) - (25 * var(--B))) / var(--A));
        --text-hover:         hsla(var(--H) var(--S) calc(var(--L) - (30 * var(--B))) / var(--A));
        --text-current:       hsla(var(--H) var(--S) calc(100 * (var(--B) + 1)) / var(--A));
        --background:         hsla(var(--H) var(--S) calc(var(--L) + (30 * var(--B))) / var(--A));
        --background-hover:   hsla(var(--H) var(--S) calc(var(--L) + (20 * var(--B))) / var(--A));
        --background-current: hsla(var(--H) var(--S) var(--L) / var(--A));
        --background-input:   hsla(var(--H) var(--S) calc(var(--L) + (45 * var(--B))) / var(--A));
        color: var(--text); font-size: var(--font-size); line-height: var(--line-height); font-weight: var(--font-weight); display: flex;
      }
      .pagy > :not([hidden]) ~ :not([hidden]) { margin-left: calc(var(--spacing) * (1 - var(--space-reverse, 0))); margin-right: calc(var(--spacing) * var(--space-reverse, 0)); }
      .rtl .pagy > :not([hidden]) ~ :not([hidden]) { --space-reverse: 1; }
      .pagy a:not([role="separator"]) { display: inline-flex; align-items: center; justify-content: center; min-width: 1.25rem; height: 1.25rem; padding: 0 calc(var(--padding) * .6); border-radius: var(--rounding); border: var(--border-width) solid #374151; background-color: var(--background); color: inherit; text-decoration: none; }
      .pagy a[href]:hover { background-color: var(--background-hover); color: var(--text-hover); }
      .pagy a:not([href]) { cursor: default; opacity: .6; }
      .pagy a[role="link"]:not([aria-current]) { opacity: .6; }
      .pagy a[aria-current] { background-color: var(--background-current); color: var(--text-current); border-color: var(--text); }
      .pagy label { white-space: nowrap; display: inline-block; border: var(--border-width) solid #374151; border-radius: var(--rounding); background-color: var(--background); padding: .15rem .4rem; }
      .pagy label input { all: unset; border: var(--border-width) solid #374151; border-radius: calc(var(--rounding) / 2) !important; background-color: var(--background-input); padding: .05rem .25rem; }
    </style>
    <style>
      /* Make Flowbite datepicker popup a bit smaller */
      .datepicker {
        font-size: 0.75rem;        /* smaller text */
        transform: scale(0.85);     /* shrink overall */
        transform-origin: top left;
      }

      /* slightly tighter cells */
      .datepicker .datepicker-cell {
        padding: 0.1rem 0.1rem;
      }

      /* header buttons a bit smaller */
      .datepicker .datepicker-header button {
        padding: 0.1rem 0.1rem;
      }
    </style>
