    <meta name="turbo-cache-control" content="no-preview">
    <meta name="rails-env" content="<%= Rails.env %>">

    <% canonical_host = ENV.fetch("APP_CANONICAL_HOST", "example.com") %>
    <% if Rails.env.production? && request.host == canonical_host %>
      <link rel="canonical" href="https://<%= request.host %><%= request.path %>">
      <meta name="description" content="<%= content_for?(:meta_description) ? yield(:meta_description) : 'Multi-tenant SaaS starter with Rails, React, and a custom admin shell.' %>">
      <meta name="keywords" content="<%= content_for?(:meta_keywords) ? yield(:meta_keywords) : 'multi-tenant saas, rails starter, react admin template' %>">
      <meta property="og:type" content="website">
      <meta property="og:url" content="https://<%= request.host %><%= request.path %>">
      <meta property="og:title" content="<%= content_for?(:title) ? yield(:title) : 'SaaS Template' %>">
      <meta property="og:description" content="<%= content_for?(:meta_description) ? yield(:meta_description) : 'Multi-tenant SaaS starter with Rails, React, and a custom admin shell.' %>">
      <meta name="twitter:card" content="summary_large_image">
      <meta name="twitter:title" content="<%= content_for?(:title) ? yield(:title) : 'SaaS Template' %>">
      <meta name="twitter:description" content="<%= content_for?(:meta_description) ? yield(:meta_description) : 'Multi-tenant SaaS starter with Rails, React, and a custom admin shell.' %>">
    <% else %>
      <meta name="robots" content="noindex, nofollow">
    <% end %>

