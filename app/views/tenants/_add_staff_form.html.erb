

  <div class="p-2 w-full max-w-2xl mx-auto space-y-3 text-xs bg-base text-primary">
    
    <%= render "shared/flash" %>

    <div class="rounded-sm border border-theme bg-surface p-3 space-y-3">
      <div class="flex items-center justify-between">
        <span class="text-[11px] text-muted">Enter the staff member’s details below.</span>
        <span class="inline-flex items-center gap-1 rounded-sm bg-elevated text-primary text-[10px] font-medium px-2 py-0.5">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 1010 10A10.011 10.011 0 0012 2zm1 15h-2v-2h2zm0-4h-2V7h2z"/></svg>
          Internal account (no self-signup)
        </span>
      </div>

      <%= form_with url: staff_create_tenant_path(id: Current.tenant), method: :post, local: true, html: { 'data-turbo': 'false' } do |f| %>
        <div class="grid grid-cols-1 sm:grid-cols-12 gap-x-3 gap-y-2 items-center">          
          <label class="sm:col-span-4 text-[11px] font-medium text-secondary leading-tight">Email
            <span class="block mt-0.5 text-[10px] text-muted font-normal">Used to sign in</span>
          </label>
          <div class="sm:col-span-8">
            <%= f.email_field :email,
                  required: true,
                  autocomplete: "off",
                  class: "h-8 w-full rounded-sm border border-theme bg-elevated px-2 text-xs text-primary placeholder-gray-500 focus:ring-blue-600 focus:border-blue-600",
                  placeholder: "name@company.com" %>
          </div>

          <!-- First name (optional) -->
          <label class="sm:col-span-4 text-[11px] font-medium text-secondary leading-tight">First name</label>
          <div class="sm:col-span-8">
            <%= f.text_field :first_name,
                  autocomplete: "off",
                  class: "h-8 w-full rounded-sm border border-theme bg-elevated px-2 text-xs text-primary placeholder-gray-500 focus:ring-blue-600 focus:border-blue-600",
                  placeholder: "Jane" %>
          </div>

          <!-- Last name (optional) -->
          <label class="sm:col-span-4 text-[11px] font-medium text-secondary leading-tight">Last name</label>
          <div class="sm:col-span-8">
            <%= f.text_field :last_name,
                  autocomplete: "off",
                  class: "h-8 w-full rounded-sm border border-theme bg-elevated px-2 text-xs text-primary placeholder-gray-500 focus:ring-blue-600 focus:border-blue-600",
                  placeholder: "Doe" %>
          </div>

          <!-- Job title (optional) -->
          <label class="sm:col-span-4 text-[11px] font-medium text-secondary leading-tight">Job title</label>
          <div class="sm:col-span-8">
            <%= f.text_field :job_title,
                  autocomplete: "off",
                  class: "h-8 w-full rounded-sm border border-theme bg-elevated px-2 text-xs text-primary placeholder-gray-500 focus:ring-blue-600 focus:border-blue-600",
                  placeholder: "Operations Manager" %>
          </div>

          <!-- Phone (optional) -->
          <label class="sm:col-span-4 text-[11px] font-medium text-secondary leading-tight">Phone
            <span class="block mt-0.5 text-[10px] text-muted font-normal">Include country code</span>
          </label>
          <div class="sm:col-span-8">
            <%= f.telephone_field :phone,
                  autocomplete: "off",
                  class: "h-8 w-full rounded-sm border border-theme bg-elevated px-2 text-xs text-primary placeholder-gray-500 focus:ring-blue-600 focus:border-blue-600",
                  placeholder: "+353 1 234 5678" %>
          </div>

          <!-- Primary staff (optional) -->
          <div class="sm:col-span-4"></div>
          <div class="sm:col-span-8">
            <label class="inline-flex items-center gap-2">
              <%= f.check_box :is_primary, class: "rounded-sm border-theme bg-elevated text-blue-600 focus:ring-blue-600" %>
              <span class="text-[11px] text-secondary">Set as Primary Staff</span>
            </label>
            <p class="mt-1 text-[10px] text-muted">Only one primary user should exist per tenant.</p>
          </div>
        </div>

        <div class="border-t border-theme my-2"></div>

        <div class="grid grid-cols-1 sm:grid-cols-12 items-center">
          <div class="sm:col-span-4 text-[10px] text-muted leading-tight">
            Staff accounts are scoped to the current tenant.
          </div>
          <div class="sm:col-span-8 flex items-center justify-end">
            <%= f.submit "Create Staff",
                  data: { disable_with: "Creating…" },
                  class: "inline-flex items-center gap-1.5 rounded-sm border px-3 py-1.5 text-xs font-medium btn-soft-blue focus:outline-none" %>
          </div>
        </div>
      <% end %>
    </div>

    <div class="rounded-sm border border-theme bg-surface text-secondary p-2 text-[11px]">
      <span>Primary User should be only one.</span>
    </div>
  </div>




