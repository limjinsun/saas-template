<% content_for :title, "SaaS Template" %>
<% content_for :meta_description, "Generic multi-tenant SaaS starter built with Rails and React." %>

<div class="relative min-h-screen overflow-hidden bg-gradient-to-b from-slate-50 to-slate-100 text-slate-900">
  <div aria-hidden="true" class="pointer-events-none absolute -top-40 -right-32 h-[32rem] w-[32rem] rounded-full bg-gradient-to-br from-[#173f62]/30 via-[#5e98c7]/20 to-transparent blur-3xl"></div>
  <div aria-hidden="true" class="pointer-events-none absolute top-[40rem] -left-40 h-[28rem] w-[28rem] rounded-full bg-gradient-to-tr from-sky-200/40 via-blue-100/30 to-transparent blur-3xl"></div>

  <header class="relative z-10 mx-auto flex max-w-6xl items-center justify-between px-6 py-5">
    <a href="<%= root_path %>" class="flex items-center gap-2">
      <img src="/marketing/saas-template-icon.svg" alt="" class="h-7 w-7" />
      <span class="text-sm font-semibold tracking-tight text-slate-900">SaaS Template</span>
    </a>
    <nav class="flex items-center gap-1 text-sm">
      <%= link_to "Admin Login", new_tenant_login_account_session_path, class: "rounded-lg px-3 py-1.5 text-slate-700 hover:bg-slate-100 transition" %>
      <%= link_to "Get Started", register_home_index_path, class: "rounded-lg bg-slate-900 px-3 py-1.5 font-medium text-white hover:bg-slate-800 transition" %>
    </nav>
  </header>

  <section class="relative z-10 mx-auto max-w-6xl px-6 pt-12 pb-24 lg:pt-20">
    <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
      <div>
        <div class="inline-flex items-center gap-2 rounded-full border border-slate-300 bg-white/80 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-600 backdrop-blur">
          <span class="relative flex h-1.5 w-1.5">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
            <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
          </span>
          Multi-tenant Rails + React starter
        </div>
        <h1 class="mt-6 text-4xl font-semibold leading-[1.05] tracking-[-0.04em] text-slate-900 sm:text-5xl lg:text-[3.5rem]">
          Start with the shell.<br>
          <span class="bg-gradient-to-r from-[#173f62] to-[#5e98c7] bg-clip-text text-transparent">Add the business later.</span>
        </h1>
        <p class="mt-6 max-w-xl text-base leading-7 text-slate-600 lg:text-[17px] lg:leading-8">
          Tenant-aware auth, subdomain routing, and a custom React admin shell — without forcing a business vertical on you.
        </p>
        <div class="mt-9 flex flex-wrap gap-3">
          <%= link_to register_home_index_path, class: "inline-flex items-center gap-2 rounded-xl bg-slate-900 px-5 py-3 text-sm font-medium text-white shadow-sm transition hover:bg-slate-800 hover:shadow-lg" do %>
            Open Registration
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          <% end %>
          <%= link_to "Admin Login", new_tenant_login_account_session_path, class: "inline-flex items-center rounded-xl border border-slate-300 bg-white px-5 py-3 text-sm font-medium text-slate-700 hover:bg-slate-50 transition" %>
        </div>
      </div>

      <div class="relative">
        <div class="absolute -inset-4 rounded-3xl bg-gradient-to-br from-[#173f62]/15 to-[#5e98c7]/10 blur-2xl"></div>
        <div class="relative rounded-2xl border border-slate-800 bg-slate-950 shadow-2xl">
          <div class="flex items-center gap-1.5 border-b border-slate-800 px-4 py-3">
            <span class="h-2.5 w-2.5 rounded-full bg-rose-400/80"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-amber-400/80"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-emerald-400/80"></span>
            <span class="ml-3 font-mono text-[10px] uppercase tracking-[0.15em] text-slate-500">config/routes.rb</span>
          </div>
<pre class="overflow-x-auto px-5 py-5 text-[12.5px] leading-[1.7] text-slate-200"><span class="text-slate-500"># Subdomain-scoped tenant routes</span>
<span class="text-violet-300">constraints</span>(<span class="text-amber-200">->(req)</span> { req.subdomain.present? }) <span class="text-violet-300">do</span>
  <span class="text-sky-300">root</span> <span class="text-emerald-300">to:</span> <span class="text-rose-300">redirect</span>(<span class="text-emerald-200">'/v2/adminFrame'</span>)

  <span class="text-sky-300">devise_for</span> <span class="text-amber-200">:tenant_staffs</span>
  <span class="text-sky-300">resources</span> <span class="text-amber-200">:tenants</span>

  <span class="text-slate-500"># React admin shell</span>
  <span class="text-sky-300">mount</span> <span class="text-violet-200">EngineB::Engine</span>, <span class="text-emerald-300">at:</span> <span class="text-emerald-200">"/v2"</span>
<span class="text-violet-300">end</span></pre>
        </div>
      </div>
    </div>
  </section>

  <section class="relative z-10 mx-auto max-w-6xl px-6 pb-16">
    <div class="grid gap-4 md:grid-cols-3">
      <% [
        ["Tenant-aware auth", "Subdomain-sensitive sign-in flows for staff and HQ users.", "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"],
        ["Custom admin shell", "React admin frame using local CoreUI components — no design lock-in.", "M4 6a2 2 0 012-2h12a2 2 0 012 2v2H4V6zm0 4h16v8a2 2 0 01-2 2H6a2 2 0 01-2-2v-8z"],
        ["Bring-your-own domain", "No business assumptions in the active surface. Add your models later.", "M12 4v16m8-8H4"]
      ].each do |title, text, icon_path| %>
        <div class="group relative overflow-hidden rounded-2xl border border-slate-200 bg-white/70 p-6 shadow-sm backdrop-blur transition hover:-translate-y-0.5 hover:shadow-md">
          <div class="mb-4 inline-flex h-9 w-9 items-center justify-center rounded-lg bg-slate-100 text-slate-700 transition group-hover:bg-[#173f62]/10 group-hover:text-[#173f62]">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.6">
              <path stroke-linecap="round" stroke-linejoin="round" d="<%= icon_path %>"/>
            </svg>
          </div>
          <h2 class="text-base font-semibold tracking-[-0.01em] text-slate-900"><%= title %></h2>
          <p class="mt-2 text-sm leading-6 text-slate-600"><%= text %></p>
        </div>
      <% end %>
    </div>
  </section>

  <section class="relative z-10 mx-auto max-w-6xl px-6 pb-20">
    <div class="rounded-3xl border border-slate-200 bg-white/60 p-8 backdrop-blur">
      <div class="text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-500">Built with</div>
      <div class="mt-4 flex flex-wrap gap-2 text-sm">
        <% %w[Rails\ 8 React\ 19 PostgreSQL CoreUI Tailwind Devise Kamal Resend].each do |name| %>
          <span class="rounded-full border border-slate-200 bg-white px-3 py-1 font-medium text-slate-700 shadow-sm"><%= name %></span>
        <% end %>
      </div>
    </div>
  </section>

  <footer class="relative z-10 border-t border-slate-200 bg-white/50 backdrop-blur">
    <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-3 px-6 py-6 text-xs text-slate-500">
      <span>© <%= Date.current.year %> SaaS Template</span>
      <span>Built on Rails + React</span>
    </div>
  </footer>
</div>
