<% content_for :title, "Create Workspace | SaaS Template" %>
<% content_for :meta_description, "Provision a tenant workspace for the generic SaaS template." %>

<section class="min-h-screen bg-[linear-gradient(180deg,#f8fafc_0%,#eef3f7_100%)] px-6 py-16">
  <div class="mx-auto max-w-3xl">
    <div class="rounded-3xl border border-slate-200 bg-white/95 p-8 shadow-sm">
      <div class="max-w-2xl">
        <div class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-500">Provisioning</div>
        <h1 class="mt-3 text-3xl font-semibold tracking-[-0.03em] text-slate-900">Create a tenant workspace</h1>
        <p class="mt-3 text-sm leading-6 text-slate-600">
          This page is intentionally simple. Use it as a starting point for your own onboarding or internal provisioning flow.
        </p>
      </div>

      <div class="mt-8 grid gap-4 md:grid-cols-2">
        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
          <h2 class="text-sm font-semibold text-slate-900">What stays</h2>
          <ul class="mt-3 space-y-2 text-sm text-slate-600">
            <li>Tenant model and subdomain routing</li>
            <li>Tenant staff and HQ login flows</li>
            <li>React admin shell under <code>/v2/adminFrame</code></li>
          </ul>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
          <h2 class="text-sm font-semibold text-slate-900">What you replace</h2>
          <ul class="mt-3 space-y-2 text-sm text-slate-600">
            <li>Marketing copy and public onboarding flow</li>
            <li>Domain models and business rules</li>
            <li>Billing, notifications, and product-specific settings</li>
          </ul>
        </div>
      </div>

      <div class="mt-8 flex flex-wrap gap-3">
        <%= link_to "Open HQ Login", new_tenant_login_account_session_path, class: "rounded-xl bg-slate-900 px-5 py-3 text-sm font-medium text-white hover:bg-slate-800" %>
        <%= link_to "Back Home", root_path, class: "rounded-xl border border-slate-300 bg-white px-5 py-3 text-sm font-medium text-slate-700 hover:bg-slate-50" %>
      </div>
    </div>
  </div>
</section>
