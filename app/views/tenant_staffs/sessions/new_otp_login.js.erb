(function(){
  var el = document.getElementById("otp-pane");
  if (!el) return;
  el.innerHTML = "<%= j render(partial: 'tenant_staffs/sessions/sub/otp_input', locals: {}) %>";
  if (el.scrollIntoView) { el.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
  if (window.__otpLoaded) { window.__otpLoaded(); }
})();