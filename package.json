{
  "name": "saas-template",
  "version": "1.0.0",
  "description": "Domain-neutral multi-tenant SaaS starter with Rails and a custom React admin shell.",
  "main": "index.js",
  "directories": {
    "lib": "lib",
    "test": "test"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "esbuild app/javascript/application_react.jsx --bundle --sourcemap --outfile=app/assets/builds/application_react.js --public-path=/assets",
    "build:watch": "yarn build --watch",
    "build:admin": "esbuild engines/engine_b/app/javascript/admin_frame/entry.jsx --bundle --sourcemap --outfile=engines/engine_b/app/assets/builds/admin_frame.js --loader:.css=css ",
    "build:admin:watch": "npm run build:admin -- --watch"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "daisyui": "^5.3.1"
  },
  "dependencies": {
    "@coreui/coreui": "^5.6.1",
    "@coreui/icons": "^3.0.1",
    "@coreui/icons-react": "^2.3.0",
    "@coreui/react": "^5.10.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hello-pangea/dnd": "^18.0.1",
    "@popperjs/core": "^2.11.8",
    "classnames": "^2.5.1",
    "esbuild": "^0.27.2",
    "grommet": "^2.54.0",
    "grommet-icons": "^4.14.0",
    "prop-types": "^15.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-transition-group": "^4.4.5",
    "styled-components": "^6.4.0"
  }
}
